{
  "entities": {
    "Booking": {
      "title": "Booking",
      "description": "Logistics and trip booking records including client details, routes, and pricing calculations",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the booking (e.g. BKG-2026-001)" },
        "customerName": { "type": "string" },
        "mobile": { "type": "string" },
        "email": { "type": "string" },
        "company": { "type": "string" },
        "address": { "type": "string" },
        "pickupAddress": { "type": "string" },
        "dropAddress": { "type": "string" },
        "pickupDate": { "type": "string" },
        "pickupTime": { "type": "string" },
        "tripType": { "type": "string", "enum": ["Airport Transfer", "Local (8 Hrs / 80 Kms)", "Local (4 Hrs / 40 Kms)", "Outstation Round Trip", "Outstation One Way", "Point to Point"] },
        "vehicleCategory": { "type": "string", "enum": ["Sedan (Dezire/Etios)", "SUV (Innova Crysta)", "Premium SUV (Fortuner)", "Luxury (Mercedes E-Class)", "Tempo Traveller (17-Seater)"] },
        "passengersCount": { "type": "number" },
        "remarks": { "type": "string" },
        "specialInstructions": { "type": "string" },
        "status": { "type": "string", "enum": ["Draft", "Confirmed", "Assigned", "Started", "Completed", "Cancelled", "Invoiced"] },
        "assignedSupplierId": { "type": "string" },
        "assignedDriverId": { "type": "string" },
        "assignedVehicleId": { "type": "string" },
        "currentLat": { "type": "number" },
        "currentLng": { "type": "number" },
        "tripProgress": { "type": "number" },
        "speedKmph": { "type": "number" },
        "kmsUsed": { "type": "number" },
        "hoursUsed": { "type": "number" },
        "tollCharges": { "type": "number" },
        "parkingCharges": { "type": "number" },
        "otherCharges": { "type": "number" },
        "discountPercentage": { "type": "number" },
        "invoiceId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "customerName", "mobile", "pickupDate", "tripType", "vehicleCategory", "status", "createdAt"]
    },
    "Driver": {
      "title": "Driver",
      "description": "Professional fleet driver profiles and status records",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "mobile": { "type": "string" },
        "licenseNumber": { "type": "string" },
        "licenseExpiry": { "type": "string" },
        "status": { "type": "string", "enum": ["Available", "On Duty", "On Leave", "Suspended"] },
        "rating": { "type": "number" },
        "shiftStart": { "type": "string" },
        "shiftEnd": { "type": "string" },
        "tripsCount": { "type": "number" },
        "baseLocation": { "type": "string" }
      },
      "required": ["id", "name", "mobile", "licenseNumber", "licenseExpiry", "status", "rating"]
    },
    "Vehicle": {
      "title": "Vehicle",
      "description": "Fleet asset details, mechanical state, and compliance documents",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "model": { "type": "string" },
        "category": { "type": "string" },
        "supplierId": { "type": "string" },
        "status": { "type": "string", "enum": ["Available", "In Trip", "Maintenance", "Inactive"] },
        "fuelType": { "type": "string", "enum": ["Diesel", "CNG", "Petrol", "Electric"] },
        "mileageKmpl": { "type": "number" },
        "fuelLevel": { "type": "number" },
        "currentLocationName": { "type": "string" },
        "documents": {
          "type": "object",
          "properties": {
            "insuranceExpiry": { "type": "string" },
            "fitnessExpiry": { "type": "string" },
            "pucExpiry": { "type": "string" },
            "permitExpiry": { "type": "string" },
            "insuranceUrl": { "type": "string" },
            "fitnessUrl": { "type": "string" },
            "pucUrl": { "type": "string" },
            "permitUrl": { "type": "string" }
          }
        }
      },
      "required": ["id", "model", "category", "supplierId", "status", "fuelType", "fuelLevel"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Third-party vendor logistics provider configuration",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "companyName": { "type": "string" },
        "mobile": { "type": "string" },
        "email": { "type": "string" },
        "gstin": { "type": "string" },
        "rating": { "type": "number" },
        "vehiclesCount": { "type": "number" },
        "commissionRate": { "type": "number" },
        "panCardNo": { "type": "string" }
      },
      "required": ["id", "name", "companyName", "mobile", "email", "gstin"]
    },
    "PassengerCompany": {
      "title": "PassengerCompany",
      "description": "Corporate passenger office details and identification details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "officeName": { "type": "string" },
        "email": { "type": "string" },
        "gstin": { "type": "string" },
        "mobile": { "type": "string" },
        "ownerName": { "type": "string" },
        "panCardNo": { "type": "string" }
      },
      "required": ["id", "officeName", "email", "gstin", "mobile", "ownerName", "panCardNo"]
    },
    "PricingRule": {
      "title": "PricingRule",
      "description": "Configurable fare structures based on geography, trip type, and vehicle type",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "vehicleCategory": { "type": "string" },
        "city": { "type": "string" },
        "tripType": { "type": "string" },
        "basePrice": { "type": "number" },
        "includedKms": { "type": "number" },
        "includedHours": { "type": "number" },
        "extraKmRate": { "type": "number" },
        "extraHourRate": { "type": "number" },
        "nightCharges": { "type": "number" },
        "waitingRatePerHour": { "type": "number" },
        "driverAllowancePerDay": { "type": "number" }
      },
      "required": ["id", "vehicleCategory", "city", "tripType", "basePrice", "includedKms", "includedHours", "extraKmRate", "extraHourRate"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Post-trip financial billing records and payment tracking",
      "type": "object",
      "properties": {
        "invoiceNumber": { "type": "string" },
        "bookingId": { "type": "string" },
        "invoiceDate": { "type": "string" },
        "dueDate": { "type": "string" },
        "baseCharge": { "type": "number" },
        "extraKmCharges": { "type": "number" },
        "extraHourCharges": { "type": "number" },
        "driverAllowance": { "type": "number" },
        "nightCharges": { "type": "number" },
        "waitingCharges": { "type": "number" },
        "tollCharges": { "type": "number" },
        "parkingCharges": { "type": "number" },
        "miscellaneousCharges": { "type": "number" },
        "subtotal": { "type": "number" },
        "discountAmount": { "type": "number" },
        "cgstAmount": { "type": "number" },
        "sgstAmount": { "type": "number" },
        "grandTotal": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["Paid", "Unpaid", "Overdue"] },
        "paymentMethod": { "type": "string", "enum": ["Bank Transfer", "Credit Card", "Corporate Wallet", "Cash"] }
      },
      "required": ["invoiceNumber", "bookingId", "invoiceDate", "dueDate", "subtotal", "grandTotal", "paymentStatus"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "description": "Enterprise security action tracker detailing system activity",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "role": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" }
      },
      "required": ["id", "timestamp", "userId", "userName", "role", "action", "details"]
    },
    "Employee": {
      "title": "Employee",
      "description": "Enterprise staff and operational operators profiles",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "mobile": { "type": "string" },
        "role": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "Inactive"] }
      },
      "required": ["id", "name", "email", "mobile", "role", "status"]
    },
    "RolePermissionConfig": {
      "title": "RolePermissionConfig",
      "description": "Custom security clearances and role-module permissions matrix configuration",
      "type": "object",
      "properties": {
        "role": { "type": "string" },
        "permissions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "module": { "type": "string" },
              "actions": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "required": ["module", "actions"]
          }
        }
      },
      "required": ["role", "permissions"]
    }
  },
  "firestore": {
    "bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Collection of all client and corporate trip reservations"
    },
    "drivers/{driverId}": {
      "schema": "Driver",
      "description": "Collection of all active fleet and supplier driver records"
    },
    "vehicles/{vehicleId}": {
      "schema": "Vehicle",
      "description": "Collection of transport asset records"
    },
    "suppliers/{supplierId}": {
      "schema": "Supplier",
      "description": "Collection of registered logistics partners and vendors"
    },
    "companies/{companyId}": {
      "schema": "PassengerCompany",
      "description": "Collection of registered passenger corporate offices and details"
    },
    "pricingRules/{pricingRuleId}": {
      "schema": "PricingRule",
      "description": "Collection of dynamic tariff models"
    },
    "invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Collection of trip billing records"
    },
    "auditLogs/{auditLogId}": {
      "schema": "AuditLog",
      "description": "Collection of operational audit and security events"
    },
    "employees/{employeeId}": {
      "schema": "Employee",
      "description": "Collection of all operational staff profiles and roles"
    },
    "rolePermissions/{roleId}": {
      "schema": "RolePermissionConfig",
      "description": "Collection of custom security access policies by role"
    }
  }
}
